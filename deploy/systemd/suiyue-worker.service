[Unit]
Description=Suiyue Worker Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/suiyue
EnvironmentFile=/etc/suiyue/suiyue.env
Environment=RAYPILOT_LOG_DIR=/root/suiyue/logs
ExecStart=/root/suiyue/deploy/scripts/hourly-log.sh worker /root/suiyue/bin/worker
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
