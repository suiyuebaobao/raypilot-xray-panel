[Unit]
Description=Suiyue API Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/suiyue
EnvironmentFile=/etc/suiyue/suiyue.env
Environment=RAYPILOT_LOG_DIR=/root/suiyue/logs
ExecStart=/root/suiyue/deploy/scripts/hourly-log.sh api /root/suiyue/bin/api
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
